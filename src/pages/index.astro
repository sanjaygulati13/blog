---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Sanjay Gulati</h1>
            <p>
                I'm a Principal Software Engineer working on static analysis
                at silicon scale. This blog covers what's adjacent to that work:
                local LLMs on consumer hardware, home lab engineering, AI agent
                systems, and the debugging discipline that connects them.
            </p>
            <p>
                The latest posts are on the <a href="/blog">blog</a>.
                More about me is on the <a href="/about">about page</a>.
            </p>
		</main>
		<Footer />
	</body>
</html>
